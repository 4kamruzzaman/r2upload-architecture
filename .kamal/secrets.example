# Reference Architecture: R2Upload API Core Secrets
# Isolated credentials strictly for the Laravel 12 API and Redis Workers

APP_KEY=$LARAVEL_APP_KEY
DATABASE_URL=$PROD_DB_URL
REDIS_URL=$PROD_REDIS_URL

# External S3-Compatible Storage Nodes
AWS_ACCESS_KEY_ID=$PROD_S3_KEY
AWS_SECRET_ACCESS_KEY=$PROD_S3_SECRET

# Billing and Webhook Integration
STRIPE_SECRET_KEY=$PROD_STRIPE_SECRET
STRIPE_WEBHOOK_SECRET=$PROD_STRIPE_WEBHOOK
