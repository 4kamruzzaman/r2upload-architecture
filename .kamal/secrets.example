# Reference Architecture: R2Upload API Core Secrets
# Isolated credentials strictly for the Laravel 12 API 

APP_KEY=$LARAVEL_APP_KEY

# Neon PostgreSQL Persistence
DB_HOST=$PROD_DB_HOST
DB_DATABASE=$PROD_DB_NAME
DB_USERNAME=$PROD_DB_USER
DB_PASSWORD=$PROD_DB_PASSWORD

# Internal Cache & Queue
REDIS_PASSWORD=$PROD_REDIS_PASSWORD

# Cloudflare R2 Storage (Zero-Egress Architecture)
R2_ENDPOINT=$PROD_R2_ENDPOINT
R2_BUCKET=$PROD_R2_BUCKET
R2_REGION=auto
R2_ACCESS_KEY=$PROD_R2_KEY
R2_SECRET_KEY=$PROD_R2_SECRET
R2_CUSTOM_DOMAIN=$PROD_R2_CDN_DOMAIN

# Billing and Webhook Integration
STRIPE_KEY=$PROD_STRIPE_PUBLIC
STRIPE_SECRET=$PROD_STRIPE_SECRET
STRIPE_WEBHOOK_SECRET=$PROD_STRIPE_WEBHOOK

# Error Telemetry
SENTRY_LARAVEL_DSN=$PROD_SENTRY_DSN
